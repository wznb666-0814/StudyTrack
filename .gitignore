# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Kotlin/Compose caches
.kotlin/

# Local Gradle distributions (avoid committing unpacked Gradle)
gradle-*-bin/
gradle-*-all/

# Local configuration file (sdk.dir is shared by all Android tools)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches

# Keystore files
*.jks
*.keystore
*.pem
*.p12
*.key

# External native build folder generated in Android Studio for Native C/C++ support
.cxx/
.externalNativeBuild/

# Google Services (e.g. APIs or Firebase)
google-services.json

# FreeMarker
*.ftl

# Auto-generated by Android Studio
.DS_Store
Thumbs.db
